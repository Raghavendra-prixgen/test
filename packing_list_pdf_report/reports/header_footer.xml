<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="amardeep_external_layout">
            <div class="article doc_report_layout_standard"
                t-att-data-oe-model="doc and doc._name"
                t-att-data-oe-id="doc and doc.id"
                t-att-data-oe-lang="doc and doc.env.context.get('lang')">
                <t t-call="web.address_layout" />
                <t t-raw="0" />
            </div>
            
            <div class="footer doc_standard_footer" style="margin-top:0;font-size:12px;">
                <div class="col-12 d-flex"
                    style="border:1px solid black; border-right:1px solid black;border-bottom:none;">
                    <div class="col-6 px-1" style="text-align:left;border-right:1px solid black;">
                        <span class="fw-bold">Receiver's Name &amp; Signature</span>
                        <br />
                        <br />
                        <br />
                        <br />
                        <br/>

                        <span>
                            <b> Date: </b>
                        </span>
                        <br />
                    </div>
                    <div class="col-6 text-end">
                        <span class="fw-bold">For</span>
                        <t t-if="doc.company_id.parent_id">
                            <span class="fw-bold" t-field="doc.company_id.sudo().parent_id.name" />
                        </t>
                        <t t-else="">
                            <span class="fw-bold" t-field="doc.company_id.name" />
                        </t>
                        <br />
                        <br />
                        <br />
                        <br />
                        <br/>
                        <span
                            style="border-top: 1px solid black; display: inline-block; width: 200px; text-align: center;">
                            <b>Authorised Signatory </b>
                        </span>
                        <br />
                    </div>
                </div>
                <div class="col-12 d-flex">
                    <div class="col-12" style="border:1px solid black;text-align:center; ">
                        <span>
                            SUBJECT TO ROORKEE JURISDICTION<br/>
                            This is a Computer Generated Invoice.
                        </span>
                    </div>
                </div>
                <div
                    style="text-align:center;padding:1px;margin-top:none !important;">
                    <p style="float:center;color:black;" class="text-muted">
                        <strong style="color:black;"> Page: <span
                                style="color:black;" class="page" />
                        <a
                                style="color:black;">/</a>
                        <span style="color:black;"
                                class="topage" />
                        </strong>
                    </p>
                </div>
            </div>
        </template>
    </data>
</odoo>