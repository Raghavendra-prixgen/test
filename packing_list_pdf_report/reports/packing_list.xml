<odoo>
    <data>
        <record id="packing_list_page_format" model="report.paperformat">
            <field name="name">Packing List page format</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">43</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">5</field>
            <field name="dpi">90</field>
        </record>

        <record id="amardeep_packing_list_report" model="ir.actions.report">
            <field name="name">Packing List</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">packing_list_pdf_report.amardeep_packing_list_pdf_report_template</field>
            <field name="report_file">packing_list_pdf_report.amardeep_packing_list_pdf_report_template</field>
            <field name="print_report_name">'Packing List - %s' % (object.name)</field>
            <field name="binding_model_id" ref="model_stock_picking" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="packing_list_pdf_report.packing_list_page_format" />
        </record>

        <template id="amardeep_packing_list_pdf_report_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="packing_list_pdf_report.amardeep_external_layout">
                        <div>
                            <table class="table table-sm"
                                style="width: 100%;font-size: 12px;">
                                <thead>
                                    <tr class="p-0">
                                        <td colspan="100%" class="p-0"
                                            style="border:1px solid black;border-bottom:none;">
                                            <table
                                                style="width: 100%; border-bottom: 1px solid black;">
                                                <tr>
                                                    <td style="width: 25%"></td>
                                                    <td
                                                        style="width: 50%; text-align: center; padding-top: 15px; ">
                                                        <span
                                                            style="font-size: 18px; font-weight: bold;">PACKING
                                                            LIST</span>
                                                    </td>
                                                    <td
                                                        style="width: 25%; text-align: right; vertical-align: middle;">
                                                        <img t-if="doc.company_id.parent_id.logo"
                                                            t-att-src="image_data_uri(doc.company_id.parent_id.logo)"
                                                            style="max-width: 150px; max-height: 60px; width: auto; height: auto; padding-right: 12px;"
                                                            alt="Logo" />
                                                        <t t-if="doc.company_id.logo">
                                                            <img
                                                                t-att-src="image_data_uri(doc.company_id.logo)"
                                                                style="max-width: 150px; max-height: 60px; width: auto; height: auto; padding-right: 12px;"
                                                                alt="Logo" />
                                                        </t>
                                                    </td>
                                                </tr>
                                            </table>

                                            <div class="col-12 d-flex"
                                                style="font-size: 12px;border-bottom:1px solid black;">
                                                <div class="col-6"
                                                    style="border-right:1px solid black;">
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Company Details</span>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-12">
                                                            <span
                                                                t-field="doc.company_id.partner_id.name" />
                                                            <br />
                                                            <t
                                                                t-if="doc.company_id.partner_id.street">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.company_id.partner_id.street" />
                                                                <br />
                                                            </t>
                                                            <t
                                                                t-if="doc.company_id.partner_id.street2">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.company_id.partner_id.street2" />
                                                                <br />
                                                            </t>
                                                            <t t-if="doc.company_id.partner_id.city">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.company_id.partner_id.city" />
                                                            </t>
                                                            <t
                                                                t-if="doc.company_id.partner_id.state_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.company_id.partner_id.state_id.name" />
                                                            </t>
                                                            <t
                                                                t-if="doc.company_id.partner_id.country_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.company_id.partner_id.country_id.name" />
                                                                <br />
                                                            </t>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">GSTIN</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span
                                                                t-field="doc.company_id.partner_id.vat" />
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">PAN</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span
                                                                t-field="doc.company_id.partner_id.l10n_in_pan_entity_id" />
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Phone No</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span
                                                                t-field="doc.company_id.partner_id.phone" />
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Email</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span
                                                                t-field="doc.company_id.partner_id.email" />
                                                        </div>
                                                    </div>

                                                </div>
                                                <div class="col-6"
                                                    style="font-size: 12px;">
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">PO No</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <t
                                                                t-if="doc.picking_type_id.name == 'Dropship'">
                                                                <span
                                                                    t-esc="doc.purchase_id.origin or ''" />
                                                            </t>
                                                            <t t-else="">
                                                                <span
                                                                    t-field="doc.sale_id.y_po_no" />
                                                            </t>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">PO Date</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <t
                                                                t-if="doc.picking_type_id.name == 'Dropship'">
                                                                <span
                                                                    t-field="doc.purchase_id.date_approve"
                                                                    t-options='{"widget":"date"}' />
                                                            </t>
                                                            <t t-else="">
                                                                <span
                                                                    t-field="doc.sale_id.y_po_date" />
                                                            </t>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Order References</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span t-field="doc.origin" />
                                                        </div>
                                                    </div>

                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Challan No</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span t-field="doc.y_challan_no" />
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Vehicle No</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span t-field="doc.y_ext_vehicle_no" />
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-3">
                                                            <span class="fw-bold">Transporter</span>
                                                        </div>
                                                        <div class="col-1">:</div>
                                                        <div class="col-8">
                                                            <span t-field="doc.y_transporter" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-12 d-flex"
                                                style="font-size: 12px;border-bottom:1px solid black;">
                                                <div class="col-6"
                                                    style="border-right:1px solid black;">
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-12">
                                                            <span class="fw-bold">Ship to (if other
                                                                than Consignee) </span>
                                                            <br />
                                                            <span
                                                                t-field="doc.partner_id.name" />
                                                            <br />
                                                            <t t-if="doc.partner_id.street">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.street" />
                                                                <br />
                                                            </t>
                                                            <t t-if="doc.partner_id.street2">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.street2" />
                                                                <br />
                                                            </t>
                                                            <t t-if="doc.partner_id.city">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.city" />
                                                            </t>
                                                            <t t-if="doc.partner_id.state_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.state_id.name" />
                                                            </t>
                                                            <t t-if="doc.partner_id.country_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.country_id.name" />
                                                                <br />
                                                            </t>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-6"
                                                    style="font-size: 12px;">
                                                    <div class="col-12 d-flex px-2">
                                                        <div class="col-12">
                                                            <span class="fw-bold">Buyer:</span>
                                                            <br />
                                                            <span
                                                                t-field="doc.partner_id.name" />
                                                            <br />
                                                            <t t-if="doc.partner_id.street">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.street" />
                                                                <br />
                                                            </t>
                                                            <t t-if="doc.partner_id.street2">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.street2" />
                                                                <br />
                                                            </t>
                                                            <t t-if="doc.partner_id.city">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.city" />
                                                            </t>
                                                            <t t-if="doc.partner_id.state_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.state_id.name" />
                                                            </t>
                                                            <t t-if="doc.partner_id.country_id.name">

                                                                <span style="font-size:12px"
                                                                    t-esc="doc.partner_id.country_id.name" />
                                                                <br />
                                                            </t>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                    <tr>
                                        <th class="p-1 text-center fw-bold"
                                            style="width:4%;border-left:1px solid black;border-right:1px solid black;">
                                            Sl.No </th>
                                        <th class="p-1 text-center fw-bold"
                                            style="width:15%;border-right:1px solid black;">
                                            Boxes &amp; Parts </th>
                                        <th class="p-1 text-center fw-bold"
                                            style="width:51%;border-right:1px solid black;">
                                            Description of Goods</th>
                                        <th class="p-1 text-center fw-bold"
                                            style="width:15%;border-right:1px solid black;">
                                            UOM</th>
                                        <th class="p-1 text-center fw-bold"
                                            style="width:15%;border-right:1px solid black;">Quantity
                                        </th>

                                    </tr>
                                </thead>
                                <tbody class="">
                                    <t t-set="sl" t-value="1" />
                                    <t t-foreach="doc.move_ids" t-as="line">
                                        <tr>
                                            <td style="border:1px solid black;text-align:center;">
                                                <span t-esc="sl" />
                                                <t t-set="sl" t-value="sl+1" />
                                            </td>
                                            <td style="border:1px solid black;text-align:center;">
                                                <span t-field="line.y_reserved_num_boxes"
                                                    t-options="{'widget': 'float', 'precision': 0}" />
                                            </td>
                                            <td style="border:1px solid black;">
                                                <span t-field="line.product_id" />
                                            </td>
                                            <td style="text-align:center;border:1px solid black;">
                                                <span t-field="line.product_uom" />
                                            </td>
                                            <td style="border:1px solid black;text-align:center;">
                                                <span t-field="line.quantity"
                                                    t-options="{'widget': 'float', 'precision': 0}" />
                                            </td>
                                        </tr>
                                    </t>

                                    <tr>
                                        <td colspan="4" class="fw-bold"
                                            style="border:1px solid black;text-align:right;">
                                            <span>Total</span>
                                        </td>
                                        <td
                                            style="border:1px solid black;border-right:1px solid black;text-align:center;">
                                            <span
                                                t-esc="sum(line.quantity for line in doc.move_ids)"
                                                t-options="{'widget': 'float', 'precision': 0}" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="5" class="fw-bold"
                                            style="border:1px solid black;">
                                            <span>Notes:</span>
                                            <br />
                                            <span t-field="doc.note" />
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>